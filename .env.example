BRIDGE_BIND=127.0.0.1:9299
HOST=
PORT=
WORK_DIR=/home/jenkins
BRIDGE_TOKEN=
BRIDGE_BASIC_AUTH=
BOTS_FILE=
FILE_SEND_ROOTS=
# Optional override for shared coordination state.
# Defaults to the bridge project directory and should be on shared durable storage
# if you run multiple bridge instances for the same bot set.
BRIDGE_SHARED_RUNTIME_ROOT=
# Optional override for instance-local runtime state such as workspaces and per-session CODEX_HOME.
# Defaults to the bridge project directory. A fast local disk is recommended.
BRIDGE_RUNTIME_ROOT=
CODEX_EXEC_MODE=host
# Optional default backend command overrides.
CODEX_COMMAND=
CLAUDE_COMMAND=
MAX_CONCURRENT_CODEX_RUNS=20
SUBPROCESS_STREAM_LIMIT=1048576
SUBPROCESS_STREAM_READ_SIZE=16384
SUBPROCESS_STREAM_MAX_LINE=262144
SCHEDULE_POLL_MS=1000
SCHEDULE_DEFINITION_POLL_MS=1000
SCHEDULE_DEFINITION_LEASE_TTL_MS=30000
PROACTIVE_SEND_ACK_TIMEOUT_SEC=10
SCHEDULE_PROCESSING_RETRY_MS=30000
SCHEDULE_ORPHAN_TTL_MS=86400000
MAX_JSON_BODY=1048576
MAX_UPLOAD_SIZE=104857600
MAX_INBOUND_IMAGE_SIZE=31457280
MAX_INBOUND_FILE_SIZE=104857600
SESSION_LEASE_TTL=30000
MEDIA_CONNECT_TIMEOUT=8000
MEDIA_TOTAL_TIMEOUT=20000
# Optional override. Relative paths are resolved from the bridge project directory.
# Default is a bridge-local queue dir under ./.local-file-send-queue
# LOCAL_FILE_SEND_QUEUE_ROOT=.local-file-send-queue
LOCAL_FILE_SEND_RESULT_TIMEOUT_MS=120000
LOCAL_FILE_SEND_RESULT_RETENTION_MS=86400000
LOCAL_FILE_SEND_POLL_MS=1000
BRIDGE_WATCHDOG_ENABLED=true
BRIDGE_WATCHDOG_POLL_SEC=5
BRIDGE_WATCHDOG_HEALTH_TIMEOUT_SEC=5
BRIDGE_WATCHDOG_STARTUP_GRACE_SEC=20
BRIDGE_WATCHDOG_FAIL_THRESHOLD=3
BRIDGE_WATCHDOG_RESTART_BACKOFF_SEC=3
BRIDGE_WATCHDOG_RESTART_WINDOW_SEC=300
BRIDGE_WATCHDOG_MAX_RESTART_STREAK=8
BRIDGE_WATCHDOG_COOLDOWN_SEC=60

# Optional: use namespaced split config instead of BRIDGE_BIND.
BRIDGE_HOST=
BRIDGE_PORT=

# Optional: bootstrap one bot on each startup so container restarts do not
# require recreating .bots.json by API.
WECOM_BOT_CONFIG_ID=
WECOM_BOT_NAME=default
WECOM_BOT_ID=
WECOM_BOT_SECRET_FILE=
WECOM_BOT_WORK_DIR=/home/jenkins
WECOM_BOT_WELCOME=
WECOM_BOT_GROUP_SESSION_MODE=per-user
WECOM_BOT_AGENT_BACKEND=codex
WECOM_BOT_AGENT_COMMAND=
WECOM_BOT_AGENT_RUN_AS_USER=
WECOM_BOT_AGENT_RUN_AS_GROUP=
WECOM_BOT_AGENT_RUNTIME_ROOT=
WECOM_BOT_ENABLED=true

# Optional fallbacks used when WECOM_BOT_AGENT_* is unset.
AGENT_BACKEND=
AGENT_COMMAND=
AGENT_RUN_AS_USER=
AGENT_RUN_AS_GROUP=
AGENT_RUNTIME_ROOT=

# Optional: bootstrap multiple bots with a JSON array string.
WECOM_BOOTSTRAP_BOTS_JSON=
WECOM_BOOTSTRAP_BOTS_JSON_FILE=
